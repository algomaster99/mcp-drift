[
  {
    "name": "search_jobs",
    "description": "Use this tool whenever the user asks to find, browse, view, recommend, or search for jobs, roles, openings, gigs, internships, or job listings. It only shows jobs that are within the United States or Canada.\nGuidelines:\n- Do not provide fields unless the user explicitly provides them.\n- The tool provides the search results all in one list, so if the user intends to search for multiple job roles, it may be better to invoke the tool for each job role separately.\n- If the user does not explicitly provide a location, you should ask the user.\n",
    "inputSchema": {
      "type": "object",
      "properties": {
        "job_role": {
          "type": "string",
          "description": "Specific job role to search for. This can be omitted if the user's intentions are to search broadly. Good example: 'software engineer', Bad example: 'sitting job'"
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Explicit skills mentioned by the user that are relevant to the job they're looking for.  Good example: 'SQL'"
        },
        "location": {
          "type": "string",
          "description": "Concrete city, state, zip code, or address to search in. Good example: 'Montreal, Quebec', Bad example: 'near me'"
        },
        "radius_miles": {
          "type": "number",
          "description": "Search radius in miles from the location."
        },
        "country_admin_code": {
          "type": "string",
          "description": "ISO-3166-1 alpha-2 country code. Only set this when a concrete location is provided and the country is known from that location. Must match the location that user wants to search in."
        },
        "max_posted_minutes_ago": {
          "type": "number",
          "minimum": 1440,
          "description": "Maximum number of minutes ago the job was posted. MIN: 1440"
        },
        "salary_min": {
          "type": "number",
          "minimum": 0,
          "maximum": 300000,
          "description": "Minimum annual salary filter. MIN: 0"
        },
        "salary_max": {
          "type": "number",
          "minimum": 0,
          "maximum": 300000,
          "description": "Maximum annual salary filter and must be greater than salary_min. MAX: 300000"
        },
        "location_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "LOCATION_TYPE_UNSPECIFIED",
              "PHYSICAL",
              "REMOTE",
              "HYBRID"
            ]
          },
          "description": "The location type of the job."
        },
        "employment_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "EMPLOYMENT_TYPE_UNSPECIFIED",
              "FULL_TIME",
              "PART_TIME",
              "CONTRACT",
              "CONTRACT_TO_HIRE",
              "TEMPORARY",
              "AS_NEEDED",
              "OTHER",
              "INTERNSHIP"
            ]
          },
          "description": "The employment type of the job."
        },
        "seniority_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "SENIORITY_CLASS_UNSPECIFIED",
              "NO_EXPERIENCE",
              "JUNIOR",
              "MID",
              "SENIOR"
            ]
          },
          "description": "The seniority class of the job."
        },
        "unsupported_filters": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Any unsupported filters provided by the user. Good examples: 401K, benefits"
        },
        "offset": {
          "type": "number",
          "description": "Number of results to skip for pagination"
        }
      },
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false,
      "openWorldHint": false
    },
    "execution": {
      "taskSupport": "forbidden"
    },
    "_meta": {
      "ui": {
        "resourceUri": "ui://widgets/job-carousel"
      },
      "openai/widgetDescription": "Renders an interactive UI showcasing job listings returned by search-jobs. The interface displays jobs in a carousel, each with company logo, job title, salary range, and location details. Each job card includes an \"View Job Details\" button that redirects users to ZipRecruiter for more details or to apply for the job.",
      "openai/toolInvocation/invoking": "Searching for jobs…",
      "openai/toolInvocation/invoked": "Finished searching",
      "ui/resourceUri": "ui://widgets/job-carousel"
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "request": {
          "type": "object",
          "properties": {
            "job_role": {
              "type": "string",
              "description": "Job role provided as input to the tool call"
            },
            "skills": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Skills provided as input to the tool call"
            },
            "location": {
              "type": "string",
              "description": "Location provided as input to the tool call"
            },
            "filters": {
              "type": "object",
              "additionalProperties": {},
              "description": "Remaining inputs provided to the tool call except 'offset'"
            }
          },
          "required": [
            "filters"
          ],
          "additionalProperties": false,
          "description": "Echo of the inputs provided to the tool call"
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "description": "Job title"
              },
              "company": {
                "type": "string",
                "description": "Company name"
              },
              "location": {
                "type": "string",
                "description": "Location of the job"
              },
              "is_remote": {
                "type": "boolean",
                "description": "Whether the job is remote"
              },
              "salary": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "min_annual": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "Minimum annual salary"
                      },
                      "max_annual": {
                        "type": [
                          "number",
                          "null"
                        ],
                        "description": "Maximum annual salary"
                      }
                    },
                    "required": [
                      "min_annual",
                      "max_annual"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Salary range of the job"
              },
              "company_logo": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "URL of the company logo"
              },
              "job_redirect_url": {
                "type": "string",
                "description": "URL to view the job listing on ZipRecruiter"
              },
              "job_type": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "The employment type and/or location type of the job"
              },
              "benefits": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Benefits provided by the job"
              },
              "days_ago": {
                "type": [
                  "number",
                  "null"
                ],
                "description": "Days since the job was posted"
              }
            },
            "required": [
              "title",
              "company",
              "location",
              "is_remote",
              "salary",
              "company_logo",
              "job_redirect_url",
              "job_type",
              "benefits",
              "days_ago"
            ],
            "additionalProperties": false
          },
          "description": "List of matching job results"
        },
        "status": {
          "type": "string",
          "enum": [
            "OK",
            "ERROR",
            "NO_RESULTS",
            "UNSUPPORTED_CONSTRAINTS",
            "UNSUPPORTED_COUNTRY"
          ],
          "description": "Response status of the tool call"
        },
        "meta": {
          "type": "object",
          "properties": {
            "count": {
              "type": "number",
              "description": "Number of job results returned by tool call"
            },
            "offset": {
              "type": "number",
              "description": "Pagination offset response is using"
            },
            "limit": {
              "type": "number",
              "description": "Maximum number of results per page"
            },
            "total": {
              "type": "number",
              "description": "Total number of matching job available"
            }
          },
          "required": [
            "count",
            "limit",
            "total"
          ],
          "additionalProperties": false,
          "description": "Response metadata from the tool call"
        },
        "errorMessage": {
          "type": "string",
          "description": "Error message from the tool call if an error occurs"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Note-worthy warnings encountered when executing the tool"
        }
      },
      "required": [
        "request",
        "status",
        "meta",
        "warnings"
      ],
      "additionalProperties": false,
      "$schema": "http://json-schema.org/draft-07/schema#"
    }
  }
]
